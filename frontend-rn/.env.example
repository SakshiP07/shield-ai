# Supabase Auth (same project as backend)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google Web Client ID from Google Cloud Console (OAuth 2.0 Web application client).
# Same value as Supabase → Authentication → Providers → Google → Client ID.
# Required for native Google Sign-In (avoids browser localhost redirects).
# Also create an Android OAuth client: package ai.shield.android + your debug SHA-1.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# FastAPI base URL for a physical Android device (use your Mac LAN IP):
#   EXPO_PUBLIC_API_BASE=http://192.168.x.x:8000/api/v1
# Android emulator only:
#   EXPO_PUBLIC_API_BASE=http://10.0.2.2:8000/api/v1
# If unset, the app tries to auto-detect the Metro LAN IP.
# EXPO_PUBLIC_API_BASE=
