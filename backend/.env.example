# App
APP_NAME=ShieldAI
DEBUG=true
API_V1_PREFIX=/api/v1

# Security
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# PostgreSQL (Docker: shieldai-postgres on port 5432)
DATABASE_URL=postgresql://shield:shield@127.0.0.1:5432/shieldai

# Redis (Docker: shieldai-redis on port 6379)
REDIS_URL=redis://127.0.0.1:6379/0

# OTP
OTP_EXPIRE_SECONDS=300
OTP_LENGTH=6
OTP_DELIVERY=console
PHONE_COUNTRY_CODE=91
PHONE_NUMBER_LENGTH=10

# MSG91 SMS (recommended for India — sends to ANY +91 number, no manual verify)
# Sign up: https://msg91.com | Auth Key: Dashboard → API → Authkey
# DLT: register template as Service Implicit (transactional OTP), must end with "- TGSP"
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=
MSG91_DLT_TE_ID=
MSG91_PE_ID=
MSG91_SMS_SUFFIX=- TGSP

# Twilio SMS (alternative — trial only sends to pre-verified numbers)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID → Web application
# Authorized redirect URIs (required for redirect sign-in):
#   http://localhost:5173/auth/google/callback
#   http://127.0.0.1:5173/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# WebAuthn / biometrics — origin must match the URL you open in the browser exactly
WEBAUTHN_RP_NAME=ShieldAI
WEBAUTHN_ORIGIN=http://localhost:5173
