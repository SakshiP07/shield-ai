# App
APP_NAME=ShieldAI
DEBUG=true
API_V1_PREFIX=/api/v1

# Security
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# Supabase / PostgreSQL
# Prefer legacy JWT keys (anon / service_role) OR new keys (sb_publishable_ / sb_secret_).
# Backend requires supabase-py >= 2.16 for sb_* keys.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DIRECT_URL=

# OTP
OTP_EXPIRE_SECONDS=300
OTP_LENGTH=6
# console = print OTP in backend logs (dev)
# twilio  = send real SMS via Twilio (needs TWILIO_* below)
# msg91   = send real SMS via MSG91
# auto    = use Twilio/MSG91 if configured, else console
OTP_DELIVERY=twilio
PHONE_COUNTRY_CODE=91
PHONE_NUMBER_LENGTH=10

# SMS (optional)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=
MSG91_DLT_TE_ID=
MSG91_PE_ID=
MSG91_SMS_SUFFIX=- TGSP
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Google OAuth is configured in the Supabase dashboard (Authentication → Providers → Google).
# Frontend callback must be allowlisted under Authentication → URL Configuration.
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
