# Google OAuth Client ID (same as backend GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=

# Google sign-in uses redirect OAuth (no GIS iframe).
# Setup in Google Cloud Console + backend/.env:
# 1. Authorized redirect URI: http://localhost:5173/auth/google/callback
# 2. backend/.env → GOOGLE_CLIENT_SECRET= (from OAuth client page)
